{
    "name": "ubermuda/gamache",
    "description": "Chief Inspector — convention checker for Symfony projects",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": ">=8.5",
        "nikic/php-parser": "^5.0",
        "symfony/console": "^6.4|^7.0|^8.0",
        "symfony/yaml": "^6.4|^7.0|^8.0"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^13.0"
    },
    "autoload": {
        "psr-4": {
            "Gamache\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Gamache\\Tests\\": "tests/"
        }
    },
    "bin": ["bin/gamache"],
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
