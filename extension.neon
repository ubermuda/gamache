parameters:
    gamache:
        controllerBaseClass: 'Symfony\Bundle\FrameworkBundle\Controller\AbstractController'
        csrfTokenAttributeClass: ''
        isGrantedAllowedAttributePrefixes:
            - 'ROLE_'
            - 'IS_AUTHENTICATED'
            - 'PUBLIC_ACCESS'
            - 'IS_IMPERSONATOR'
        translationCallSites: []
        translationAttributeSites: []
        repositoryNamingExcludedClasses:
            - 'Doctrine\ORM\EntityRepository'
            - 'Doctrine\Bundle\DoctrineBundle\Repository\ServiceEntityRepository'
            - 'Doctrine\Persistence\ObjectRepository'
        controllerTemplates:
            # Regex over controller FQCNs; capture group 1 is the module-relative
            # namespace path mirrored under templateDirectory. Empty = rule off.
            namespacePattern: ''
            # Template root the captured module path is appended to, relative to
            # the working directory (or absolute). Empty = rule off.
            templateDirectory: ''
            # Method names whose first argument renders a page template.
            renderMethods:
                - render
        templateNamespaces:
            # Template-path prefix that must be referenced through a Twig
            # namespace instead (e.g. 'Module/' -> @<Module>/...). Empty = rule off.
            forbiddenPathPrefix: ''
            renderMethods:
                - render
                - renderView
                - htmlTemplate
                - textTemplate

parametersSchema:
    gamache: structure([
        controllerBaseClass: string()
        csrfTokenAttributeClass: string()
        isGrantedAllowedAttributePrefixes: listOf(string())
        translationCallSites: listOf(structure([
            class: string()
            method: string()
            argumentIndex: int()
        ]))
        translationAttributeSites: listOf(structure([
            class: string()
            argumentNames: listOf(string())
        ]))
        repositoryNamingExcludedClasses: listOf(string())
        controllerTemplates: structure([
            namespacePattern: string()
            templateDirectory: string()
            renderMethods: listOf(string())
        ])
        templateNamespaces: structure([
            forbiddenPathPrefix: string()
            renderMethods: listOf(string())
        ])
    ])

services:
    -
        class: Gamache\PHPStan\TranslationKeyValidator
    -
        class: Gamache\PHPStan\TranslationCallSiteRule
        arguments:
            callSites: %gamache.translationCallSites%
        tags:
            - phpstan.rules.rule
    -
        class: Gamache\PHPStan\TranslationAttributeRule
        arguments:
            attributeSites: %gamache.translationAttributeSites%
        tags:
            - phpstan.rules.rule
    -
        class: Gamache\PHPStan\MigrationDescriptionRule
        tags:
            - phpstan.rules.rule
    -
        class: Gamache\PHPStan\ApiRouteConsistencyRule
        tags:
            - phpstan.rules.rule
    -
        class: Gamache\PHPStan\ApiControllerInputBindingRule
        tags:
            - phpstan.rules.rule
    -
        class: Gamache\PHPStan\ControllerParentRule
        arguments:
            controllerBaseClass: %gamache.controllerBaseClass%
        tags:
            - phpstan.rules.rule
    -
        class: Gamache\PHPStan\ControllerSingleActionRule
        arguments:
            controllerBaseClass: %gamache.controllerBaseClass%
        tags:
            - phpstan.rules.rule
    -
        class: Gamache\PHPStan\ControllerRouteAttributeRule
        arguments:
            controllerBaseClass: %gamache.controllerBaseClass%
        tags:
            - phpstan.rules.rule
    -
        class: Gamache\PHPStan\VoterNotReadonlyRule
        tags:
            - phpstan.rules.rule
    -
        class: Gamache\PHPStan\EnumKebabCaseRule
        tags:
            - phpstan.rules.rule
    -
        class: Gamache\PHPStan\NotBlankNullableRule
        tags:
            - phpstan.rules.rule
    -
        class: Gamache\PHPStan\HandlerShapeRule
        tags:
            - phpstan.rules.rule
    -
        class: Gamache\PHPStan\CommandShapeRule
        tags:
            - phpstan.rules.rule
    -
        class: Gamache\PHPStan\FormDataClassNotEntityRule
        tags:
            - phpstan.rules.rule
    -
        class: Gamache\PHPStan\BuildFormConstraintsRule
        tags:
            - phpstan.rules.rule
    -
        class: Gamache\PHPStan\RouteParamCamelCaseRule
        tags:
            - phpstan.rules.rule
    -
        class: Gamache\PHPStan\IsGrantedVoterConstantRule
        arguments:
            allowedAttributePrefixes: %gamache.isGrantedAllowedAttributePrefixes%
        tags:
            - phpstan.rules.rule
    -
        class: Gamache\PHPStan\IsGrantedClassLevelRule
        arguments:
            controllerBaseClass: %gamache.controllerBaseClass%
        tags:
            - phpstan.rules.rule
    -
        class: Gamache\PHPStan\IsGrantedNoFullyAuthRule
        tags:
            - phpstan.rules.rule
    -
        class: Gamache\PHPStan\DenyAccessUnlessGrantedRule
        arguments:
            controllerBaseClass: %gamache.controllerBaseClass%
        tags:
            - phpstan.rules.rule
    -
        class: Gamache\PHPStan\CsrfTokenAttributeRule
        arguments:
            controllerBaseClass: %gamache.controllerBaseClass%
            csrfTokenAttributeClass: %gamache.csrfTokenAttributeClass%
        tags:
            - phpstan.rules.rule
    -
        class: Gamache\PHPStan\EntityAsymmetricVisibilityRule
        tags:
            - phpstan.rules.rule
    -
        class: Gamache\PHPStan\DtoRequestSuffixRule
        tags:
            - phpstan.rules.rule
    -
        class: Gamache\PHPStan\RouteNoUnderscorePrefixRule
        tags:
            - phpstan.rules.rule
    -
        class: Gamache\PHPStan\RepositoryParameterNameRule
        arguments:
            excludedClasses: %gamache.repositoryNamingExcludedClasses%
        tags:
            - phpstan.rules.rule
    -
        class: Gamache\PHPStan\ControllerTemplateNameRule
        arguments:
            namespacePattern: %gamache.controllerTemplates.namespacePattern%
            templateDirectory: %gamache.controllerTemplates.templateDirectory%
            renderMethods: %gamache.controllerTemplates.renderMethods%
            currentWorkingDirectory: %currentWorkingDirectory%
        tags:
            - phpstan.rules.rule
    -
        class: Gamache\PHPStan\ModuleTemplateNamespaceRule
        arguments:
            forbiddenPathPrefix: %gamache.templateNamespaces.forbiddenPathPrefix%
            renderMethods: %gamache.templateNamespaces.renderMethods%
        tags:
            - phpstan.rules.rule
    -
        class: Gamache\PHPStan\MessengerHandlerNamespaceRule
        tags:
            - phpstan.rules.rule
